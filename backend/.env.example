APP_NAME=AI Stock Analytics Dashboard
ENV=development
API_PREFIX=/api

DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/stockdb
REDIS_URL=redis://redis:6379/0

FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=
POLYGON_API_KEY=
TIINGO_API_KEY=
LIVE_DATA_ONLY=true
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_DATA_FEED=iex
ALPACA_DATA_BASE=https://data.alpaca.markets
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets
ALPACA_STREAM_URL=wss://stream.data.alpaca.markets/v2/iex

BINANCE_WS_URL=wss://stream.binance.com:9443/stream
BINANCE_REST_URL=https://api.binance.com
BINANCE_US_FALLBACK=true
COINGECKO_DEMO_KEY=
COINGECKO_BASE=https://api.coingecko.com/api/v3
MARKETAUX_API_KEY=
ALPHAVANTAGE_NEWS_ENABLED=true
NEWS_RSS_SOURCES=yahoo,google_news
NEWS_POLL_INTERVAL_SECONDS=60
SENTIMENT_PRIMARY=gpt-4o-mini
SENTIMENT_FALLBACK=vader
OPENAI_SENTIMENT_BATCH_SIZE=10
PROVIDER_HEALTH_WINDOW_SECONDS=300
PROVIDER_FAILOVER_ENABLED=true
RATE_LIMIT_REDIS_PREFIX=ratelimit:
FEATURE_ALERTS_ENABLED=false
FEATURE_CANDLESTICK_CHART=false

BROKER_MODE=paper
ANALYTICS_ONLY_MODE=true

JWT_SECRET=change-me-in-prod
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

TELEGRAM_BOT_TOKEN=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

NOTIFICATION_RETRY_MAX=3

DEFAULT_TICKERS=AAPL,MSFT,TSLA,NVDA,AMZN
MARKET_STREAM_ENABLED=true
MARKET_STREAM_PROVIDER=auto
MARKET_STREAM_THROTTLE_SECONDS=1.0
SYMBOL_SYNC_ON_STARTUP=false
UPDATE_INTERVAL_SECONDS=15
MODEL_RETRAIN_MINUTES=30

FRONTEND_ORIGIN=http://localhost:5173
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
